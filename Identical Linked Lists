class Solution {
    // Function to check whether two linked lists are identical or not.
    public boolean areIdentical(Node head1, Node head2) {
        Node current1 = head1;
        Node current2 = head2;

        // Traverse both lists until one (or both) reach the end
        while (current1 != null && current2 != null) {
            // If data doesn't match, they aren't identical
            if (current1.data != current2.data) {
                return false;
            }
            
            // Move both pointers forward
            current1 = current1.next;
            current2 = current2.next;
        }

        // If both reached null, they are identical in length and data.
        // If one is NOT null, then one list was longer than the other.
        return (current1 == null && current2 == null);
    }
}
