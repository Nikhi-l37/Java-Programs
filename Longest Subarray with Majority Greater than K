class Solution {
    public int longestSubarray(int[] arr, int k) {
        int n = arr.length;
        int maxLen = 0;
        int sum = 0;
        // Map stores the first occurrence of a prefix sum
        Map<Integer, Integer> map = new HashMap<>();

        for (int i = 0; i < n; i++) {
            // Transform: > k is +1, <= k is -1
            sum += (arr[i] > k) ? 1 : -1;

            // Case 1: Entire prefix from 0 to i is valid
            if (sum > 0) {
                maxLen = i + 1;
            } 
            // Case 2: Look for a prefix sum that makes the remaining part > 0
            // If current sum is <= 0, we need to subtract a smaller sum (sum - 1)
            // to get a net positive subarray sum of 1.
            else if (map.containsKey(sum - 1)) {
                maxLen = Math.max(maxLen, i - map.get(sum - 1));
            }

            // Store the first occurrence of this sum to keep subarrays as long as possible
            if (!map.containsKey(sum)) {
                map.put(sum, i);
            }
        }
        return maxLen;
    }
}
