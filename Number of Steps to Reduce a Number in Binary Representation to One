class Solution {
    public int numSteps(String s) {
        int steps = 0;
        int carry = 0;

        // Iterate from right to left, stopping before the first character
        // because we want to reach "1", not "0".
        for (int i = s.length() - 1; i > 0; i--) {
            int digit = (s.charAt(i) - '0') + carry;

            if (digit == 1) {
                // If current bit is 1 (or 0 with carry), it's odd.
                // Rule: Add 1 (1 step) + Divide by 2 (1 step) = 2 steps.
                // The "add 1" creates a carry for the next bit.
                steps += 2;
                carry = 1;
            } else {
                // If digit is 0 (or 1 with carry), it's effectively even.
                // Rule: Just divide by 2 (1 step).
                steps += 1;
                // carry remains what it was (if it was 1, it stays 1; 0 stays 0)
            }
        }

        // Final step: handle the leftmost '1' and the remaining carry.
        // If there is a carry, the leading '1' becomes '10', needing 1 more divide.
        return steps + carry;
    }
}
