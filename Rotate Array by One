class Solution {
    public void rotate(int[] arr) {
        // code here
        
        for(int i=0;i<arr.length/2;i++){
            int temp = arr[i];
             arr[i] = arr[arr.length-i-1] ;
            arr[arr.length-i-1]  =  temp;
        }
        
        
          for(int i=1;i<=arr.length/2;i++){
            int temp = arr[i];
             arr[i] = arr[arr.length-i] ;
            arr[arr.length-i]  =  temp;
        }
    
    }
}
