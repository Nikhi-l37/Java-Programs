/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class Solution {
    public int sumRootToLeaf(TreeNode root) {
        return dfs(root, 0);
    }

    private int dfs(TreeNode node, int currentSum) {
        // Base case: if node is null, contribute nothing to the sum
        if (node == null) {
            return 0;
        }

        // Update the current path's binary value
        // Equivalent to: currentSum * 2 + node.val
        currentSum = (currentSum << 1) | node.val;

        // If it's a leaf node, return the completed binary number
        if (node.left == null && node.right == null) {
            return currentSum;
        }

        // Recursively find sums of left and right subtrees
        return dfs(node.left, currentSum) + dfs(node.right, currentSum);
    }
}
